# PostgreSQL connection URL for API (preferred)
APP_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ligamx
# Backward-compatible fallback:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ligamx

# Optional: separate DB only for Script 01_GetODDS
# ODDS_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ligamx

# JWT secret used to sign access tokens (change in production)
JWT_SECRET=change_this_secret

# Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API-Football setup (Script 01_GetODDS)
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=replace_with_real_key
# Use these two only if you call through RapidAPI:
# API_FOOTBALL_HEADER_NAME=x-rapidapi-key
# API_FOOTBALL_HOST_HEADER=api-football-v1.p.rapidapi.com

# Liga MX odds fetch window
LIGAMX_LEAGUE_ID=262
LIGAMX_SEASON=2026
ODDS_LOOKAHEAD_DAYS=5
# Optional override for free plans/historical backfills (YYYY-MM-DD)
# ODDS_START_DATE=2024-03-01
ODDS_TIMEZONE=America/Mexico_City
ODDS_BOOKMAKER=Bet365
# ODDS_BOOKMAKER_ID=8
ODDS_REQUEST_TIMEOUT_SECONDS=25
ODDS_REQUEST_DELAY_SECONDS=0.25
