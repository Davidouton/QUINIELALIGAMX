{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "startCommand": "RUN_STARTUP_MIGRATIONS=false PYTHONPATH=. uvicorn app.main:app --host 0.0.0.0 --port $PORT --ws none --workers ${WEB_CONCURRENCY:-2}",
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
